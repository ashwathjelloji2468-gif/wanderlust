<% layout('layouts/boilerplate') -%>

    <% if (success && success.length> 0) { %>
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <% success.forEach((msg)=> { %>
                <div>
                    <%= msg %>
                </div>
                <% }) %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <% } %>

            <% if (error && error.length> 0) { %>
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <% error.forEach((msg)=> { %>
                        <div>
                            <%= msg %>
                        </div>
                        <% }) %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>

                    <div class="airbnb-toggle-wrapper">
                        <div class="airbnb-toggle-scroll">
                            <button
                                class="airbnb-toggle-item <%= !selectedCategory || selectedCategory === 'All' ? 'active' : '' %>"
                                data-filter="All" type="button">
                                <i class="fa-solid fa-border-all"></i>
                                <span>All</span>
                            </button>

                            <button class="airbnb-toggle-item <%= selectedCategory === 'Cabins' ? 'active' : '' %>"
                                data-filter="Cabins" type="button">
                                <i class="fa-solid fa-house-chimney"></i>
                                <span>Cabins</span>
                            </button>

                            <button class="airbnb-toggle-item <%= selectedCategory === 'Beach' ? 'active' : '' %>"
                                data-filter="Beach" type="button">
                                <i class="fa-solid fa-umbrella-beach"></i>
                                <span>Beach</span>
                            </button>

                            <button class="airbnb-toggle-item <%= selectedCategory === 'Luxury' ? 'active' : '' %>"
                                data-filter="Luxury" type="button">
                                <i class="fa-solid fa-gem"></i>
                                <span>Luxury</span>
                            </button>
                        </div>

                        <div class="filters-switch">
                            <div class="form-check form-switch">
                                <input class="form-check-input tax-switch" type="checkbox" role="switch" id="taxSwitch">
                                <label class="form-check-label" for="taxSwitch">Display total with taxes</label>
                            </div>
                        </div>
                    </div>

                    <% if (!allListings || allListings.length===0) { %>
                        <div class="text-center py-5">
                            <h4 class="mb-2">No listings found</h4>
                            <p class="text-muted mb-0">Try creating a new listing or changing the filter.</p>
                        </div>
                        <% } else { %>
                            <div class="row row-cols-1 row-cols-md-3 g-4" id="listings-container">
                                <% for (let listing of allListings) { %>
                                    <div class="col listing-card" data-category="<%= listing.category || 'All' %>">
                                        <div class="card h-100 shadow-sm">
                                            <img src="<%= (listing.image && listing.image.url) ? listing.image.url : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800&auto=format&fit=crop' %>"
                                                class="card-img-top" alt="<%= listing.title || 'Listing image' %>">

                                            <div class="card-body d-flex flex-column">
                                                <h5 class="card-title mb-2">
                                                    <%= listing.title || 'Untitled Listing' %>
                                                </h5>

                                                <p class="card-text flex-grow-1">
                                                    <%= listing.description
                                                        || 'Amazing stay with comfort and great surroundings.' %>
                                                </p>

                                                <p class="mb-2 text-muted">
                                                    <i class="fa-solid fa-location-dot me-1"></i>
                                                    <%= listing.location || 'Unknown location' %>, <%= listing.country
                                                            || 'Unknown country' %>
                                                </p>

                                                <p class="mb-1 fw-semibold listing-price">
                                                    ₹<span class="base-price">
                                                        <%= listing.price ? listing.price.toLocaleString("en-IN") : '0'
                                                            %>
                                                    </span>
                                                    <span class="price-with-tax d-none">
                                                        <%= listing.price ? Math.round(listing.price *
                                                            1.18).toLocaleString("en-IN") : '0' %>
                                                    </span>
                                                    / night
                                                </p>

                                                <p class="tax-info d-none">
                                                    <i>+18% GST</i>
                                                </p>

                                                <a href="/listings/<%= listing._id %>" class="btn btn-primary mt-auto">
                                                    View Details
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>
                            </div>
                            <% } %>

                                <script>
                                    document.addEventListener("DOMContentLoaded", () => {
                                        const toggleButtons = document.querySelectorAll(".airbnb-toggle-item");
                                        const listingCards = document.querySelectorAll(".listing-card");
                                        const taxSwitch = document.getElementById("taxSwitch");

                                        toggleButtons.forEach((button) => {
                                            button.addEventListener("click", () => {
                                                const filter = button.dataset.filter;

                                                toggleButtons.forEach((btn) => btn.classList.remove("active"));
                                                button.classList.add("active");

                                                listingCards.forEach((card) => {
                                                    const category = card.dataset.category;

                                                    if (filter === "All" || category === filter) {
                                                        card.style.display = "block";
                                                    } else {
                                                        card.style.display = "none";
                                                    }
                                                });
                                            });
                                        });

                                        if (taxSwitch) {
                                            taxSwitch.addEventListener("change", () => {
                                                const allBasePrices = document.querySelectorAll(".base-price");
                                                const allTaxPrices = document.querySelectorAll(".price-with-tax");
                                                const allTaxInfo = document.querySelectorAll(".tax-info");

                                                if (taxSwitch.checked) {
                                                    allBasePrices.forEach((el) => el.classList.add("d-none"));
                                                    allTaxPrices.forEach((el) => el.classList.remove("d-none"));
                                                    allTaxInfo.forEach((el) => el.classList.remove("d-none"));
                                                } else {
                                                    allBasePrices.forEach((el) => el.classList.remove("d-none"));
                                                    allTaxPrices.forEach((el) => el.classList.add("d-none"));
                                                    allTaxInfo.forEach((el) => el.classList.add("d-none"));
                                                }
                                            });
                                        }
                                    });
                                </script>