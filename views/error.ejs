<% layout('layouts/boilerplate') -%>
<div class="row mt-3">
    <div class="alert alert-danger col-6 offset-3 shadow-lg border-0" role="alert">
        <!-- Custom SVG icon (no Bootstrap Icons needed) -->
        <div class="alert-icon mb-3">
            <svg viewBox="0 0 24 24" fill="currentColor" class="text-danger" width="48" height="48">
                <path d="M12 2L2 22h20L12 2zM13 17h-2v-2h2v2zM13 13h-2V7h2v6z"/>
            </svg>
        </div>
        
        <h4 class="alert-heading fw-bold"><%= err.message || 'Oops! Something broke...' %></h4>
        
        <!-- Custom trace with copy button -->
        <details class="mt-2">
            <summary class="btn-link small">🛠️ Show technical details</summary>
            <pre class="mt-2 p-3 bg-dark text-white small rounded"><%= err.stack || err.trace %></pre>
        </details>
        
        <!-- Unique "try again" layout -->
        <div class="mt-4 pt-3 border-top">
            <a href="javascript:window.location.reload()" class="btn btn-danger me-2 px-4">
            </a>
            <a href="/" class="btn btn-outline-light px-4">🏠 Home</a>
        </div>
    </div>
</div>

<style>
.alert-icon svg { filter: drop-shadow(0 4px 8px rgba(220,53,69,0.3)); }
details summary { cursor: pointer; color: #dc3545 !important; }
details summary:hover { text-decoration: underline; }
</style>
