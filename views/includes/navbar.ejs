<nav class="navbar navbar-expand-md sticky-top airbnb-navbar">
  <div class="container-fluid px-3 px-md-4">

    <!-- Logo -->
    <a class="navbar-brand d-flex align-items-center gap-2 fw-bold" href="/listings">
      <i class="fa-regular fa-compass"></i>
      <span>Wanderlust</span>
    </a>

    <!-- Mobile toggle -->
    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false"
      aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse mt-3 mt-md-0" id="navbarNavAltMarkup">

      <!-- LEFT LINKS -->
      <div class="navbar-nav me-md-4 align-items-md-center">
        <a class="nav-link airbnb-link" href="/listings">Explore</a>
        <a class="nav-link airbnb-link" href="/listings/new">Airbnb your home</a>
      </div>

      <!-- CENTER SEARCH -->
      <form class="d-flex mx-md-auto my-3 my-md-0 airbnb-search" role="search" action="/listings" method="GET">
        <input class="form-control border-0 shadow-none" type="search" name="search" placeholder="Start your search"
          aria-label="Search listings" value="<%= typeof searchValue !== 'undefined' ? searchValue : '' %>" />
        <button class="btn airbnb-search-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </form>

      <!-- RIGHT SIDE -->
      <div class="navbar-nav ms-md-4 align-items-md-center airbnb-auth">
        <% if (!currUser) { %>
          <a class="nav-link airbnb-link" href="/signup"><b>Sign up</b></a>
          <a class="nav-link airbnb-login-btn" href="/login"><b>Log in</b></a>
          <% } else { %>
            <span class="nav-link airbnb-user-pill">
              <i class="fa-regular fa-circle-user me-1"></i>
              <%= currUser.username %>
            </span>
            <a class="nav-link airbnb-logout" href="/logout">Log out</a>
            <% } %>
      </div>

    </div>
  </div>
</nav>